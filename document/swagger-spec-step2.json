  "info": {
    "title": "Game Backend API",
    "description": "REST API per app di gioco e dashboard di gestione livelli/mondi",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "worlds",
      "description": "Gestione mondi di gioco"
    },
    {
      "name": "levels",
      "description": "Gestione livelli"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "WorldResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "uuid-1234"
          },
          "name": {
            "type": "string",
            "example": "Ice Kingdom"
          },
          "description": {
            "type": "string",
            "example": "Un regno ghiacciato con 10 livelli"
          },
          "stageNumber": {
            "type": "number",
            "example": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PUBLISHED",
              "ARCHIVED"
            ],
            "example": "PUBLISHED"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "levels": {
            "example": true,
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "stageNumber",
          "status",
          "isActive",
          "levels",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateLevelDto": {
        "type": "object",
        "properties": {}
      },
      "CreateWorldDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Ice Kingdom",
            "description": "Nome univoco del mondo",
            "minLength": 3
          },
          "color": {
            "type": "string",
            "example": "RED",
            "description": "Colore del mondo"
          },
          "icon": {
            "type": "string",
            "example": "🍓",
            "description": "Icona del mondo"
          },
          "description": {
            "type": "string",
            "example": "Un regno ghiacciato con 10 livelli",
            "description": "Descrizione opzionale del mondo"
          },
          "stageNumber": {
            "type": "number",
            "example": 1,
            "description": "Numero del mondo"
          },
          "levels": {
            "description": "Lista dei livelli associati a questo mondo (creazione opzionale)",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateLevelDto"
            }
          }
        },
        "required": [
          "name",
          "stageNumber"
        ]
      },
      "WorldRequestDto": {
        "type": "object",
        "properties": {
          "worlds": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateWorldDto"
            }
          }
        },
        "required": [
          "worlds"
        ]
      },
      "PublishBulkDto": {
        "type": "object",
        "properties": {
          "ids": {
            "example": [
              "uuid-1",
              "uuid-2"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "ids"
        ]
      },
      "UpdateWorldDto": {
        "type": "object",
        "properties": {}
      },
      "RegisterTokenDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
