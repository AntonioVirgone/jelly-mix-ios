  "info": {
    "title": "JellyMix API",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "WorldResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "uuid-1234"
          },
          "name": {
            "type": "string",
            "example": "Ice Kingdom"
          },
          "description": {
            "type": "string",
            "example": "Un regno ghiacciato con 10 livelli"
          },
          "stageNumber": {
            "type": "number",
            "example": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PUBLISHED",
              "ARCHIVED"
            ],
            "example": "PUBLISHED"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "levels": {
            "example": true,
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "stageNumber",
          "status",
          "isActive",
          "levels",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateLevelDto": {
        "type": "object",
        "properties": {}
      },
      "CreateWorldDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Ice Kingdom",
            "description": "Nome univoco del mondo",
            "minLength": 3
          },
          "color": {
            "type": "string",
            "example": "RED",
            "description": "Colore del mondo"
          },
          "icon": {
            "type": "string",
            "example": "🍓",
            "description": "Icona del mondo"
          },
          "description": {
            "type": "string",
            "example": "Un regno ghiacciato con 10 livelli",
            "description": "Descrizione opzionale del mondo"
          },
          "stageNumber": {
            "type": "number",
            "example": 1,
            "description": "Numero del mondo"
          },
          "levels": {
            "description": "Lista dei livelli associati a questo mondo (creazione opzionale)",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateLevelDto"
            }
          }
        },
        "required": [
          "name",
          "stageNumber"
        ]
      },
      "WorldRequestDto": {
        "type": "object",
        "properties": {
          "worlds": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateWorldDto"
            }
          }
        },
        "required": [
          "worlds"
        ]
      },
      "PublishBulkDto": {
        "type": "object",
        "properties": {
          "ids": {
            "example": [
              "uuid-1",
              "uuid-2"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "ids"
        ]
      },
      "UpdateWorldDto": {
        "type": "object",
        "properties": {}
      },
      "RegisterTokenDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "fcm-device-token-xyz"
          },
          "platform": {
            "type": "string",
            "enum": [
              "ios",
              "android"
            ],
            "example": "android"
          }
        },
        "required": [
          "token",
          "platform"
        ]
      },
      "SendTestNotificationDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "fcm-device-token-xyz"
          },
          "title": {
            "type": "string",
            "example": "Titolo test"
          },
          "body": {
            "type": "string",
            "example": "Messaggio di test"
          }
        },
        "required": [
          "token"
        ]
      },
      "LevelResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "uuid-1234"
          },
          "levelNumber": {
            "type": "number",
            "example": 1
          },
          "levelIndex": {
            "type": "number",
            "example": 1
          },
          "worldId": {
            "type": "string",
            "example": "uuid-world-5678"
          },
          "movesLimit": {
            "type": "number",
            "example": 10
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "PUBLISHED",
              "ARCHIVED"
            ],
            "example": "PUBLISHED"
          },
          "objective": {
            "type": "object",
            "example": {
              "type": "JELLY",
              "required": 5
            }
          },
          "grid": {
            "example": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "availablePieces": {
            "example": [],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "levelNumber",
          "levelIndex",
          "movesLimit",
          "status",
          "objective",
          "grid",
          "availablePieces",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateLevelDto": {
        "type": "object",
        "properties": {}
      },
      "CreateDataLoggerDto": {
        "type": "object",
        "properties": {}
      },
      "DataLoggerResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "uuid-1234"
          },
          "type": {
            "type": "string",
            "example": "GAME"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "type",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "Nome visualizzato (max 30 caratteri)"
          },
          "username": {
            "type": "string",
            "description": "Username univoco: lowercase, lettere/numeri/underscore, 3-20 caratteri"
          },
          "avatarCode": {
            "type": "string",
            "description": "Codice preset avatar"
          }
        }
      },
      "FriendCurrentLevelDto": {
        "type": "object",
        "properties": {
          "levelNumber": {
            "type": "number"
          },
          "levelIndex": {
            "type": "number"
          }
        },
        "required": [
          "levelNumber",
          "levelIndex"
        ]
      },
      "FriendProgressEntryDto": {
        "type": "object",
        "properties": {
          "worldId": {
            "type": "string"
          },
          "worldName": {
            "type": "string"
          },
          "stageNumber": {
            "type": "number"
          },
          "worldIcon": {
            "type": "string"
          },
          "isWorldComplete": {
            "type": "boolean"
          },
          "currentLevel": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/FriendCurrentLevelDto"
              }
            ]
          }
        },
        "required": [
          "worldId",
          "worldName",
          "stageNumber",
          "worldIcon",
          "isWorldComplete"
        ]
      },
      "FriendProgressDto": {
        "type": "object",
        "properties": {
          "friendId": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "avatarCode": {
            "type": "object",
            "nullable": true
          },
          "currentStageNumber": {
            "type": "number",
            "nullable": true
          },
          "worlds": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FriendProgressEntryDto"
            }
          }
        },
        "required": [
          "friendId",
          "displayName",
          "worlds"
        ]
      },
      "FriendsProgressResponseDto": {
        "type": "object",
        "properties": {
          "friends": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FriendProgressDto"
            }
          }
        },
        "required": [
          "friends"
        ]
      },
      "ReportProgressDto": {
        "type": "object",
        "properties": {
          "worldId": {
            "type": "string",
            "description": "ID del mondo corrente"
          },
          "levelId": {
            "type": "string",
            "description": "ID del livello appena completato"
          },
          "isWorldComplete": {
            "type": "boolean",
            "description": "true se l'utente ha completato l'ultimo livello del mondo",
            "default": false
          }
        },
        "required": [
          "worldId",
          "levelId"
        ]
      },
      "CurrentLevelDto": {
        "type": "object",
        "properties": {
          "levelId": {
            "type": "string"
          },
          "levelNumber": {
            "type": "number"
          },
          "levelIndex": {
            "type": "number"
          }
        },
        "required": [
          "levelId",
          "levelNumber",
          "levelIndex"
        ]
      },
      "ProgressEntryDto": {
        "type": "object",
        "properties": {
          "worldId": {
            "type": "string"
          },
          "worldName": {
            "type": "string"
          },
          "stageNumber": {
            "type": "number"
          },
          "worldIcon": {
            "type": "string"
          },
          "worldColor": {
            "type": "string"
          },
          "isWorldComplete": {
            "type": "boolean"
          },
          "completedAt": {
            "type": "string",
            "nullable": true
          },
          "currentLevel": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/CurrentLevelDto"
              }
            ]
          }
        },
        "required": [
          "worldId",
          "worldName",
          "stageNumber",
          "worldIcon",
          "worldColor",
          "isWorldComplete"
        ]
      },
      "MyProgressResponseDto": {
        "type": "object",
        "properties": {
          "currentStageNumber": {
            "type": "number",
            "nullable": true
          },
          "worlds": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ProgressEntryDto"
            }
          }
        },
        "required": [
          "worlds"
        ]
      },
      "InviteResponseDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
