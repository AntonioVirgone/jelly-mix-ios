        "tags": [
          "friendships"
        ]
      }
    },
    "/friendships/{id}": {
      "delete": {
        "operationId": "FriendshipsController_removeFriend",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "ID della Friendship",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "summary": "Rimuovi un amico (cancella la Friendship ACCEPTED)",
        "tags": [
          "friendships"
        ]
      }
    },
    "/hearts/config": {
      "get": {
        "operationId": "HeartsController_getConfig",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeartsConfigResponseDto"
                }
              }
            }
          }
        },
        "summary": "Parametri cuori (pubblico) — heartRechargeMinutes, maxHearts, maxHeartsReceivedPerDay",
        "tags": [
          "hearts"
        ]
      }
    },
    "/hearts/send/{friendId}": {
      "post": {
        "operationId": "HeartsController_sendHeart",
        "parameters": [
          {
            "name": "friendId",
            "required": true,
            "in": "path",
            "description": "ID utente destinatario",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "summary": "Invia un cuore a un amico (max 1 al giorno per amico)",
        "tags": [
          "hearts"
        ]
      }
    },
    "/hearts/request": {
      "post": {
        "operationId": "HeartsController_requestHearts",
        "parameters": [],
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "requested": {
                      "type": "number"
                    }
                  }
                }
              }
            }
          }
        },
        "summary": "Richiedi cuori a tutti gli amici (batch push FCM)",
        "tags": [
          "hearts"
        ]
      }
    },
    "/hearts/fulfill/{requestId}": {
      "post": {
        "operationId": "HeartsController_fulfillRequest",
        "parameters": [
          {
            "name": "requestId",
            "required": true,
            "in": "path",
            "description": "ID della HeartRequest",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "summary": "Evadi una richiesta cuore ricevuta (invia cuore al richiedente)",
        "tags": [
          "hearts"
        ]
      }
    },
    "/hearts/consume": {
      "post": {
        "operationId": "HeartsController_consumeHeart",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConsumeHeartResponseDto"
                }
              }
            }
          }
        },
        "summary": "Consuma un cuore (chiamato quando si perde un livello)",
        "tags": [
          "hearts"
        ]
      }
    },
    "/hearts/requests/incoming": {
      "get": {
        "operationId": "HeartsController_getIncomingRequests",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/HeartRequestResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "Richieste cuore ricevute in attesa (PENDING, non scadute)",
        "tags": [
          "hearts"
        ]
      }
    }
