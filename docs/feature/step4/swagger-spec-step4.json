          "expiresAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "code",
          "expiresAt"
        ]
      },
      "FriendProfileDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "playerNumber": {
            "type": "number"
          },
          "displayName": {
            "type": "string"
          },
          "avatarCode": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id",
          "playerNumber",
          "displayName"
        ]
      },
      "FriendshipResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "friend": {
            "$ref": "#/components/schemas/FriendProfileDto"
          }
        },
        "required": [
          "id",
          "status",
          "createdAt",
          "friend"
        ]
      },
      "HeartsConfigResponseDto": {
        "type": "object",
        "properties": {
          "heartRechargeMinutes": {
            "type": "number"
          },
          "maxHearts": {
            "type": "number"
          },
          "maxHeartsReceivedPerDay": {
            "type": "number"
          }
        },
        "required": [
          "heartRechargeMinutes",
          "maxHearts",
          "maxHeartsReceivedPerDay"
        ]
      },
      "ConsumeHeartResponseDto": {
        "type": "object",
        "properties": {
          "heartsCount": {
            "type": "number"
          },
          "lastHeartConsumedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "heartsCount",
          "lastHeartConsumedAt"
        ]
      },
      "HeartRequestSenderDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "playerNumber": {
            "type": "number"
          },
          "displayName": {
            "type": "string"
          },
          "avatarCode": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id",
          "playerNumber",
          "displayName"
        ]
      },
      "HeartRequestResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "expiresAt": {
            "format": "date-time",
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "requester": {
            "$ref": "#/components/schemas/HeartRequestSenderDto"
          }
        },
        "required": [
          "id",
          "status",
          "expiresAt",
          "createdAt",
          "requester"
        ]
      }
    }
  }
