{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": { "200": { "description": "" } },
        "tags": ["App"]
      }
    },
    "/api/v1/worlds": {
      "get": {
        "operationId": "WorldsController_findAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/WorldResponseDto" }
                }
              }
            }
          }
        },
        "summary": "Lista tutti i mondi attivi",
        "tags": ["worlds"]
      },
      "post": {
        "operationId": "WorldsController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateWorldDto" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorldResponseDto" }
              }
            }
          },
          "400": { "description": "Validation error" }
        },
        "summary": "Crea un nuovo mondo",
        "tags": ["worlds"]
      }
    },
    "/api/v1/worlds/{id}": {
      "get": {
        "operationId": "WorldsController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "example": "uuid-1234", "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorldResponseDto" }
              }
            }
          },
          "404": { "description": "World not found" }
        },
        "summary": "Recupera un mondo per ID",
        "tags": ["worlds"]
      },
      "put": {
        "operationId": "WorldsController_update",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "example": "uuid-1234", "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateWorldDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorldResponseDto" }
              }
            }
          },
          "404": { "description": "World not found" }
        },
        "summary": "Aggiorna un mondo esistente",
        "tags": ["worlds"]
      },
      "delete": {
        "operationId": "WorldsController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "example": "uuid-1234", "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "World disattivato" },
          "404": { "description": "World not found" }
        },
        "summary": "Soft-delete di un mondo",
        "tags": ["worlds"]
      }
    },
    "/api/v1/worlds/bulk": {
      "post": {
        "operationId": "WorldsController_createWorlds",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorldRequestDto" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/WorldResponseDto" }
                }
              }
            }
          },
          "400": { "description": "Validation error" }
        },
        "summary": "Crea multipli mondi (e i loro livelli) in blocco",
        "tags": ["worlds"]
      }
    },
    "/api/v1/notifications/register": {
      "post": {
        "operationId": "NotificationsController_registerToken",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterTokenDto" }
            }
          }
        },
        "responses": { "201": { "description": "Token registrato" } },
        "summary": "Registra un device token FCM",
        "tags": ["notifications"]
      }
    },
    "/api/v1/notifications/token/{token}": {
      "delete": {
        "operationId": "NotificationsController_removeToken",
        "parameters": [
          {
            "name": "token",
            "required": true,
            "in": "path",
            "description": "FCM device token",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "204": { "description": "Token rimosso" } },
        "summary": "Rimuovi un device token (es. al logout)",
        "tags": ["notifications"]
      }
    },
    "/api/v1/levels": {
      "get": {
        "operationId": "LevelsController_findAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/LevelResponseDto" }
                }
              }
            }
          }
        },
        "summary": "Lista tutti i mondi attivi",
        "tags": ["levels"]
      },
      "post": {
        "operationId": "LevelsController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateLevelDto" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LevelResponseDto" }
              }
            }
          },
          "400": { "description": "Validation error" }
        },
        "summary": "Crea un nuovo mondo",
        "tags": ["levels"]
      }
    },
    "/api/v1/levels/{id}": {
      "get": {
        "operationId": "LevelsController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "example": "uuid-1234", "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LevelResponseDto" }
              }
            }
          },
          "404": { "description": "World not found" }
        },
        "summary": "Recupera un mondo per ID",
        "tags": ["levels"]
      },
      "put": {
        "operationId": "LevelsController_update",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "example": "uuid-1234", "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateLevelDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LevelResponseDto" }
              }
            }
          },
          "404": { "description": "World not found" }
        },
        "summary": "Aggiorna un mondo esistente",
        "tags": ["levels"]
      },
      "delete": {
        "operationId": "LevelsController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "example": "uuid-1234", "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "World disattivato" },
          "404": { "description": "World not found" }
        },
        "summary": "Soft-delete di un mondo",
        "tags": ["levels"]
      }
    },
    "/api/v1/data-logger": {
      "post": {
        "operationId": "DataLoggerController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateDataLoggerDto" }
            }
          }
        },
        "responses": { "201": { "description": "" } },
        "tags": ["data-logger"]
      },
      "get": {
        "operationId": "DataLoggerController_findAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DataLoggerResponseDto"
                  }
                }
              }
            }
          }
        },
        "summary": "Lista tutti i log",
        "tags": ["data-logger"]
      }
    },
    "/api/v1/data-logger/{id}": {
      "get": {
        "operationId": "DataLoggerController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "tags": ["data-logger"]
      },
      "delete": {
        "operationId": "DataLoggerController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "tags": ["data-logger"]
      }
    }
  },
  "info": {
    "title": "Game Backend API",
    "description": "REST API per app di gioco e dashboard di gestione livelli/mondi",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    { "name": "worlds", "description": "Gestione mondi di gioco" },
    { "name": "levels", "description": "Gestione livelli" }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "access-token": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "WorldResponseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "uuid-1234" },
          "name": { "type": "string", "example": "Ice Kingdom" },
          "description": {
            "type": "string",
            "example": "Un regno ghiacciato con 10 livelli"
          },
          "stageNumber": { "type": "number", "example": 1 },
          "isActive": { "type": "boolean", "example": true },
          "levels": {
            "example": true,
            "type": "array",
            "items": { "type": "string" }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "stageNumber",
          "isActive",
          "levels",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateLevelDto": { "type": "object", "properties": {} },
      "CreateWorldDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Ice Kingdom",
            "description": "Nome univoco del mondo",
            "minLength": 3
          },
          "color": {
            "type": "string",
            "example": "RED",
            "description": "Colore del mondo"
          },
          "icon": {
            "type": "string",
            "example": "🍓",
            "description": "Icona del mondo"
          },
          "description": {
            "type": "string",
            "example": "Un regno ghiacciato con 10 livelli",
            "description": "Descrizione opzionale del mondo"
          },
          "stageNumber": {
            "type": "number",
            "example": 1,
            "description": "Numero del mondo"
          },
          "levels": {
            "description": "Lista dei livelli associati a questo mondo (creazione opzionale)",
            "type": "array",
            "items": { "$ref": "#/components/schemas/CreateLevelDto" }
          }
        },
        "required": ["name", "stageNumber"]
      },
      "WorldRequestDto": {
        "type": "object",
        "properties": {
          "worlds": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/CreateWorldDto" }
          }
        },
        "required": ["worlds"]
      },
      "UpdateWorldDto": { "type": "object", "properties": {} },
      "RegisterTokenDto": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "example": "fcm-device-token-xyz" },
          "platform": {
            "type": "string",
            "enum": ["ios", "android"],
            "example": "android"
          }
        },
        "required": ["token", "platform"]
      },
      "LevelResponseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "uuid-1234" },
          "name": { "type": "string", "example": "Ice Kingdom" },
          "description": {
            "type": "string",
            "example": "Un regno ghiacciato con 10 livelli"
          },
          "stageNumber": { "type": "number", "example": 1 },
          "isActive": { "type": "boolean", "example": true },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "name",
          "stageNumber",
          "isActive",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateLevelDto": { "type": "object", "properties": {} },
      "CreateDataLoggerDto": { "type": "object", "properties": {} },
      "DataLoggerResponseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "uuid-1234" },
          "type": { "type": "string", "example": "GAME" },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2024-01-01T00:00:00.000Z"
          }
        },
        "required": ["id", "type", "createdAt", "updatedAt"]
      }
    }
  }
}
